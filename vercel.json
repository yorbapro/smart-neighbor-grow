{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/client",
  "cleanUrls": true,

  "headers": [
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon-:size(32|16|192|512)x:size.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],

  "rewrites": [
    { "source": "/~oauth/initiate", "destination": "https://smart-neighbor-grow.lovable.app/~oauth/initiate" },
    { "source": "/~oauth/callback", "destination": "https://smart-neighbor-grow.lovable.app/~oauth/callback" },
    { "source": "/(.*)", "destination": "/api/prerender" }
  ]
}
